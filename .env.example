# News Discovery Environment Configuration

# Application
ND_APP_NAME=news-discovery
ND_DEBUG=true

# PostgreSQL
# Local development: use localhost
# Docker: use service name (postgres)
ND_POSTGRES__DSN=postgresql+asyncpg://postgres:postgres@localhost:5432/news_discovery
# For Docker use: postgresql+asyncpg://postgres:postgres@postgres:5432/news_discovery

# Neo4j
# Local development: use localhost
# Docker: use service name (neo4j)
ND_NEO4J__URI=bolt://localhost:7687
ND_NEO4J__USER=neo4j
ND_NEO4J__PASSWORD=neo4j123
# For Docker use: bolt://neo4j:7687

# Redis
# Local development: use localhost
# Docker: use service name (redis)
ND_REDIS__URL=redis://localhost:6379/0
# For Docker use: redis://redis:6379/0

# LLM (OpenAI)
ND_LLM__PROVIDERS__OPENAI__API_KEY=your-api-key-here

# API
ND_API__API_KEY=dev-api-key-change-in-production
ND_API__HOST=0.0.0.0
ND_API__PORT=8000
