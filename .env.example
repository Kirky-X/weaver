# Weaver Environment Variables Template - Secrets Only
# Copy this file to .env and fill in your values
# Other configurations are in config/settings.toml

# Environment (development, staging, production)
ENVIRONMENT=development

# PostgreSQL Password (used in DSN)
POSTGRES_PASSWORD=your_secure_postgres_password

# Neo4j Password
WEAVER_NEO4J__PASSWORD=your_secure_neo4j_password

# API Key (at least 32 characters in production)
WEAVER_API__API_KEY=your_secure_api_key_at_least_32_characters_long

# LLM Provider API Keys
# Local providers (no key needed)
WEAVER_LLM__PROVIDERS__CC_OPENAI__API_KEY=not-needed
WEAVER_LLM__PROVIDERS__CC_CLAUDE__API_KEY=not-needed
WEAVER_LLM__PROVIDERS__IFLOW_LOCAL__API_KEY=not-needed
WEAVER_LLM__PROVIDERS__OLLAMA__API_KEY=not-needed

# Cloud providers (set your API keys)
WEAVER_LLM__PROVIDERS__IFLOW_API_QWEN__API_KEY=your_iflow_api_key
WEAVER_LLM__PROVIDERS__IFLOW_API_DEEPSEEK__API_KEY=your_iflow_api_key
WEAVER_LLM__PROVIDERS__OPENAI__API_KEY=your_openai_api_key
