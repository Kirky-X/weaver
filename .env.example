# Weaver Environment Variables - Secrets Only
# ============================================================
# SECURITY: Copy this file to .env and fill in your values
# NEVER commit the .env file with real credentials!
# Service URLs should be in config/settings.toml
# ============================================================

# Environment
ENVIRONMENT=development

# PostgreSQL
POSTGRES_PASSWORD=your_secure_postgres_password

# Neo4j
NEO4J_PASSWORD=your_secure_neo4j_password

# Redis (optional, leave empty if no auth)
REDIS_PASSWORD=

# API Authentication (at least 32 characters in production)
WEAVER_API__API_KEY=your_secure_api_key_at_least_32_characters_long

# LLM Provider API Keys (referenced in config/llm.toml)
# Use ${ENV_VAR_NAME} syntax in llm.toml, e.g.: api_key = "${OPENAI_API_KEY}"
# Add your provider API keys below:
OPENAI_API_KEY=your_openai_api_key
ANTHROPIC_API_KEY=your_anthropic_api_key
# Add other provider keys as needed, e.g.:
# ZHIPU_API_KEY=your_zhipu_api_key
# DEEPSEEK_API_KEY=your_deepseek_api_key
