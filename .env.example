# Weaver Environment Variables Template - Secrets Only
# ============================================================
# SECURITY: Copy this file to .env and fill in your values
# NEVER commit the .env file with real credentials!
# ============================================================

# Environment (development, staging, production)
ENVIRONMENT=development

# ============================================================
# PostgreSQL Configuration
# ============================================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_postgres_password_here
WEAVER_POSTGRES__DSN=postgresql+asyncpg://postgres:your_secure_postgres_password_here@localhost:5434/weaver

# ============================================================
# Neo4j Configuration
# ============================================================
NEO4J_URI=bolt://localhost:7689
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_secure_neo4j_password_here

# ============================================================
# Redis Configuration
# ============================================================
WEAVER_REDIS__URL=redis://localhost:6381/0

# ============================================================
# API Authentication
# ============================================================
# API Key for service authentication (at least 32 characters in production)
API_KEY=your_secure_api_key_at_least_32_characters_long_here
WEAVER_API__API_KEY=your_secure_api_key_at_least_32_characters_long_here

# ============================================================
# LLM Provider API Keys
# ============================================================

# Local providers (no key needed for local LLM services)
WEAVER_LLM__PROVIDERS__CC_OPENAI__API_KEY=not-needed
WEAVER_LLM__PROVIDERS__CC_CLAUDE__API_KEY=not-needed
WEAVER_LLM__PROVIDERS__IFLOW_LOCAL__API_KEY=not-needed
WEAVER_LLM__PROVIDERS__OLLAMA__API_KEY=not-needed

# Cloud providers - set your actual API keys
WEAVER_LLM__PROVIDERS__IFLOW_API_QWEN__API_KEY=your_iflow_api_key_here
WEAVER_LLM__PROVIDERS__IFLOW_API_DEEPSEEK__API_KEY=your_iflow_api_key_here
WEAVER_LLM__PROVIDERS__OPENAI__API_KEY=your_openai_api_key_here

# Legacy LLM API key (if needed)
IFLOW_API_KEY=your_iflow_api_key_here

# ============================================================
# Optional: Advanced Configuration
# ============================================================
# Uncomment to override defaults:
# WEAVER_POSTGRES__POOL_SIZE=10
# WEAVER_POSTGRES__MAX_OVERFLOW=20
# WEAVER_REDIS__MAX_CONNECTIONS=20