# Weaver Environment Variables Template - Secrets Only
# Copy this file to .env and fill in your values
# Other configurations are in config/settings.toml

# Environment (development, staging, production)
ENVIRONMENT=development

# PostgreSQL Password (used in DSN)
POSTGRES_PASSWORD=your_secure_postgres_password

# Neo4j Password
ND_NEO4J__PASSWORD=your_secure_neo4j_password

# API Key (at least 32 characters in production)
ND_API__API_KEY=your_secure_api_key_at_least_32_characters_long

# LLM Provider API Keys
ND_LLM__PROVIDERS__IFLOW__API_KEY=your_iflow_api_key
ND_LLM__PROVIDERS__ZHIPU__API_KEY=your_zhipu_api_key
ND_LLM__PROVIDERS__CC_STITCH__API_KEY=your_cc_stitch_api_key
