# Weaver Environment Variables - Secrets Only
# ============================================================
# SECURITY: Copy this file to .env and fill in your values
# NEVER commit the .env file with real credentials!
# Service URLs should be in config/settings.toml
# ============================================================
#
# Environment Variable Format:
# - Prefix: WEAVER_ (single underscore)
# - Nested delimiter: __ (double underscore)
# - Example: WEAVER_POSTGRES__PASSWORD=secret
# ============================================================

# Environment
ENVIRONMENT=development

# PostgreSQL
WEAVER_POSTGRES__PASSWORD=your_secure_postgres_password

# Neo4j (REQUIRED in production - no default password)
WEAVER_NEO4J__PASSWORD=your_secure_neo4j_password

# Redis (optional, leave empty if no auth)
WEAVER_REDIS__PASSWORD=

# API Authentication (at least 32 characters in production)
WEAVER_API__API_KEY=your_secure_api_key_at_least_32_characters_long

# LLM Provider API Keys
# These override empty values in config/llm.toml
WEAVER_LLM__PROVIDERS__AIPING__API_KEY=your_aiping_api_key
WEAVER_LLM__PROVIDERS__DMX__API_KEY=your_dmx_api_key
# Ollama doesn't need a real API key
# WEAVER_LLM__PROVIDERS__OLLAMA__API_KEY=ollama

# Other provider keys as needed:
# OPENAI_API_KEY=your_openai_api_key
# ANTHROPIC_API_KEY=your_anthropic_api_key