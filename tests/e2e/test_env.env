"""Environment variables for E2E tests.

This file configures the application to connect to the E2E Docker services.
Copy to .env.test for local testing.
"""

# PostgreSQL settings (PostgresSettings uses POSTGRES_ prefix)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DATABASE=weaver

# Redis settings (RedisSettings uses REDIS_ prefix)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Neo4j settings (Neo4jSettings uses NEO4J_ prefix)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password
NEO4J_ENABLED=true

# Application settings (Settings uses WEAVER_ prefix with nested delimiter __)
WEAVER_API__API_KEY=e2e-test-api-key-32chars-long!!
WEAVER_API__HOST=0.0.0.0
WEAVER_API__PORT=8001

# Environment
ENVIRONMENT=testing
DEBUG=true

# Disable OpenTelemetry in tests
WEAVER_OBSERVABILITY__OTLP_ENDPOINT=

# LLM settings for tests
WEAVER_LLM__PROVIDERS__OLLAMA__API_KEY=sk-test