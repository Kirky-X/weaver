"""Environment variables for E2E tests.

This file configures the application to connect to the E2E Docker services.
Copy to .env.test for local testing.

Environment Variable Format:
- Prefix: WEAVER_ (single underscore)
- Nested delimiter: __ (double underscore)
- Example: WEAVER_POSTGRES__HOST=localhost
"""

# PostgreSQL settings
WEAVER_POSTGRES__HOST=localhost
WEAVER_POSTGRES__PORT=5432
WEAVER_POSTGRES__USER=postgres
WEAVER_POSTGRES__PASSWORD=postgres
WEAVER_POSTGRES__DATABASE=weaver

# Redis settings
WEAVER_REDIS__HOST=localhost
WEAVER_REDIS__PORT=6379
WEAVER_REDIS__DB=0

# Neo4j settings
WEAVER_NEO4J__URI=bolt://localhost:7687
WEAVER_NEO4J__USER=neo4j
WEAVER_NEO4J__PASSWORD=password
WEAVER_NEO4J__ENABLED=true

# API settings
WEAVER_API__API_KEY=e2e-test-api-key-32chars-long!!
WEAVER_API__HOST=0.0.0.0
WEAVER_API__PORT=8001

# Environment
ENVIRONMENT=testing
DEBUG=true

# Disable OpenTelemetry in tests
WEAVER_OBSERVABILITY__OTLP_ENDPOINT=

# LLM settings for tests
WEAVER_LLM__PROVIDERS__OLLAMA__API_KEY=sk-test